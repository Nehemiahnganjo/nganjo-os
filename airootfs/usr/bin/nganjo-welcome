#!/usr/bin/env bash
# Ng'anjo OS — Welcome TUI Script
# Creator: Nehemiah Ng'anjo

# ── Colors ─────────────────────────────────────────────────────────────────────
TEAL='\033[38;2;0;210;180m'
GOLD='\033[38;2;255;209;102m'
WHITE='\033[38;2;230;237;245m'
GRAY='\033[38;2;100;110;130m'
RED='\033[38;2;255;77;109m'
GREEN='\033[38;2;6;214;160m'
RESET='\033[0m'
BOLD='\033[1m'

# ── Ensure display is set ──────────────────────────────────────────────────────
export DISPLAY="${DISPLAY:-:0}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"

show_banner() {
    clear
    echo -e "${TEAL}${BOLD}"
    cat << 'EOF'

   ███╗   ██╗ ██████╗     █████╗ ███╗  ██╗     ██╗ ██████╗      ██████╗ ███████╗
   ████╗  ██║██╔════╝    ██╔══██╗████╗ ██║     ██║██╔═══██╗    ██╔═══██╗██╔════╝
   ██╔██╗ ██║██║  ███╗   ███████║██╔██╗██║     ██║██║   ██║    ██║   ██║███████╗
   ██║╚██╗██║██║   ██║   ██╔══██║██║╚████║██   ██║██║   ██║    ██║   ██║╚════██║
   ██║ ╚████║╚██████╔╝   ██║  ██║██║ ╚███║╚█████╔╝╚██████╔╝    ╚██████╔╝███████║
   ╚═╝  ╚═══╝ ╚═════╝    ╚═╝  ╚═╝╚═╝  ╚══╝ ╚════╝  ╚═════╝      ╚═════╝ ╚══════╝

EOF
    echo -e "${RESET}"
    echo -e "   ${GOLD}${BOLD}Version 1.0 Lite — \"Arise\"${RESET}   ${GRAY}│   Creator: Nehemiah Ng'anjo${RESET}"
    echo -e "   ${GRAY}Arch Linux based  │  x86_64  │  $([ "$XDG_CURRENT_DESKTOP" = "KDE" ] && echo "KDE Plasma on Wayland" || echo "GNOME on Wayland")${RESET}"
    echo ""
    echo -e "   ${TEAL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""
}

show_sysinfo() {
    echo -e "   ${BOLD}${WHITE}System Information${RESET}"
    echo ""
    CPU=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ //' || echo "Unknown")
    RAM=$(free -h 2>/dev/null | awk '/^Mem:/{print $2}' || echo "Unknown")
    DISK=$(lsblk -d -o NAME,SIZE 2>/dev/null | grep -v NAME | grep -v loop | head -1 | awk '{print $1" "$2}' || echo "Unknown")
    GPU=$(lspci 2>/dev/null | grep -iE 'vga|3d|display' | head -1 | sed 's/.*: //' || echo "Unknown")
    KERNEL=$(uname -r)
    echo -e "   ${TEAL}CPU    ${RESET}${WHITE}${CPU}${RESET}"
    echo -e "   ${TEAL}GPU    ${RESET}${WHITE}${GPU}${RESET}"
    echo -e "   ${TEAL}RAM    ${RESET}${WHITE}${RAM}${RESET}"
    echo -e "   ${TEAL}Disk   ${RESET}${WHITE}${DISK}${RESET}"
    echo -e "   ${TEAL}Kernel ${RESET}${WHITE}${KERNEL}${RESET}"
    echo ""
    echo -e "   ${TEAL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""
}

do_install() {
    echo ""
    echo -e "   ${TEAL}${BOLD}Launching Ng'anjo OS Installer...${RESET}"
    echo ""

    if ! command -v calamares &>/dev/null; then
        echo -e "   ${RED}Calamares installer not found.${RESET}"
        echo -e "   ${GRAY}Connect to internet and run: yay -S calamares${RESET}"
        echo ""
        echo -ne "   Press Enter to return to menu... "
        read -r
        return
    fi

    # Launch Calamares GUI in background
    if [[ $EUID -eq 0 ]]; then
        calamares &>/dev/null &
    elif command -v pkexec &>/dev/null; then
        pkexec --disable-internal-agent calamares &>/dev/null &
    else
        sudo -E calamares &>/dev/null &
    fi

    echo -e "   ${GREEN}Calamares installer launched!${RESET}"
    echo -e "   ${GRAY}Follow the graphical steps to install Ng'anjo OS.${RESET}"
    echo ""
    echo -ne "   Press Enter to return to menu... "
    read -r
}

do_live() {
    echo ""
    echo -e "   ${GREEN}${BOLD}Welcome to the Ng'anjo OS live session!${RESET}"
    echo ""
    echo -e "   ${WHITE}You can explore the system without installing anything.${RESET}"
    echo -e "   ${GRAY}Run 'nganjo-installer' anytime to install to disk.${RESET}"
    echo -e "   ${GRAY}Run 'nganjo-setup' after installing for post-install setup.${RESET}"
    echo ""
    echo -ne "   Press Enter to return to menu... "
    read -r
}

do_terminal() {
    echo ""
    echo -e "   ${TEAL}Opening terminal...${RESET}"
    echo ""
    if command -v konsole &>/dev/null; then
        konsole &
    elif command -v gnome-terminal &>/dev/null; then
        gnome-terminal &
    elif command -v xterm &>/dev/null; then
        xterm &
    else
        echo -e "   ${RED}No terminal emulator found.${RESET}"
        echo -ne "   Press Enter... "
        read -r
        return
    fi
    sleep 1
}

# ── Main loop ──────────────────────────────────────────────────────────────────
while true; do
    show_banner
    show_sysinfo

    echo -e "   ${GOLD}${BOLD}What would you like to do?${RESET}"
    echo ""
    echo -e "   ${TEAL}[1]${RESET}  ${WHITE}Install Ng'anjo OS to disk${RESET}"
    echo -e "   ${TEAL}[2]${RESET}  ${WHITE}Try the live session (no install)${RESET}"
    echo -e "   ${TEAL}[3]${RESET}  ${WHITE}Open a terminal${RESET}"
    echo -e "   ${TEAL}[4]${RESET}  ${WHITE}Exit${RESET}"
    echo ""
    echo -ne "   ${GOLD}Choice [1-4]: ${RESET}"
    read -r choice

    case "$choice" in
        1) do_install ;;
        2) do_live ;;
        3) do_terminal ;;
        4) clear; exit 0 ;;
        *) echo -e "\n   ${RED}Invalid choice. Please enter 1-4.${RESET}"; sleep 1 ;;
    esac
done
