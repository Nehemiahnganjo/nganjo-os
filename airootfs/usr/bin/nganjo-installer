#!/usr/bin/env bash
# Ng'anjo OS — Installer Launcher
# Creator: Nehemiah Ng'anjo

export DISPLAY="${DISPLAY:-:0}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"

if command -v konsole &>/dev/null; then
    exec konsole --title "Ng'anjo OS Installer" -e bash -c "sudo nganjo-install; exec bash"
elif command -v gnome-terminal &>/dev/null; then
    exec gnome-terminal --title="Ng'anjo OS Installer" -- bash -c "sudo nganjo-install; exec bash"
else
    exec sudo nganjo-install
fi
